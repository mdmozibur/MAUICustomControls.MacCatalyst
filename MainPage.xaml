<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MAUICustomControls.MacCatalyst.Controls"
             xmlns:customObjects="clr-namespace:MAUICustomControls.MacCatalyst.Controls.CustomObjects"
             xmlns:local="clr-namespace:MAUICustomControls.MacCatalyst"
             x:Class="MAUICustomControls.MacCatalyst.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <controls:PopoverButton 
                x:Name="popoverButton" 
                HorizontalOptions="Center" 
                BorderColor="White" 
                BorderWidth="2" 
                WidthRequest="200"
                PopoverDirection="Down"
                Padding="10"
                BackgroundColor="Gray">        

                <Label Text="Click Me" FontSize="22" VerticalOptions="Center" HorizontalOptions="Center" />

                <controls:PopoverButton.PopoverContent>
                    <VerticalStackLayout Padding="10" Spacing="10" HorizontalOptions="Center">
                        <Label FontSize="22" Text="This is a simple popover."/>
                        <Button Text="Close" Clicked="Button_Clicked"/>
                    </VerticalStackLayout>
                </controls:PopoverButton.PopoverContent>
            </controls:PopoverButton>

            <controls:ToggleButton 
                x:Name="toggleButton" 
                HorizontalOptions="Center" 
                Foreground="SaddleBrown"
                Background="Transparent"
                WidthRequest="300"
                HeightRequest="60"
                IconGlyph="square.split.bottomrightquarter"
                Text="Toggle Me"/>
        
            <controls:ComboBox 
                x:Name="comboBox"
                UnselectedText="Select an option"
                HorizontalOptions="Center" 
                BorderThickness="1"
                WidthRequest="200">
                <controls:ComboBox.Options>
                    <x:Array Type="{x:Type customObjects:SelectorOption}">
                        <customObjects:SelectorOption Text="Option 1" SystemIconName="star"/>
                        <customObjects:SelectorOption Text="Option 2" SystemIconName="heart"/>
                        <customObjects:SelectorOption Text="Option 3" SystemIconName="bolt"/>
                        <customObjects:SelectorOption Text="Option 4" SystemIconName="flame"/>
                        <customObjects:SelectorOption Text="Option 5" SystemIconName="cloud"/>
                    </x:Array>
                </controls:ComboBox.Options>
            </controls:ComboBox>
        
            <controls:ToggleDropdown 
                x:Name="DropdownBox"
                HorizontalOptions="Center" 
                TintColor="DodgerBlue"
                BorderThickness="1"
                WidthRequest="200">
                <controls:ToggleDropdown.Options>
                    <x:Array Type="{x:Type customObjects:SelectorOption}">
                        <customObjects:SelectorOption Text="Option 1" SystemIconName="star"/>
                        <customObjects:SelectorOption Text="Option 2" SystemIconName="heart"/>
                        <customObjects:SelectorOption Text="Option 3" SystemIconName="bolt"/>
                        <customObjects:SelectorOption Text="Option 4" SystemIconName="flame"/>
                        <customObjects:SelectorOption Text="Option 5" SystemIconName="cloud"/>
                    </x:Array>
                </controls:ToggleDropdown.Options>
            </controls:ToggleDropdown>
        
            <controls:ToggleDropdown 
                x:Name="DropdownBox2"
                HorizontalOptions="Center" 
                TintColor="DodgerBlue"
                BorderThickness="1"
                WidthRequest="200">
            </controls:ToggleDropdown>

            <controls:CheckBox Text="Check me"
                HorizontalOptions="Center"
                CheckedChanged="CheckBox_CheckedChanged" />

            <Label Text="Switches"
                FontSize="28"
                FontAttributes="Bold" />

            <controls:ToggleSwitch Text="One"
                HorizontalOptions="Fill"
                IsOn="True"
                OnColor="DodgerBlue"
                Foreground="White" />

            <controls:ToggleSwitch Text="Two"
                HorizontalOptions="Fill"
                Foreground="White" />

            <controls:CustomTabView
                x:Name="TabsControl"
                AddButtonVisibility="True"
                ScrollButtonsVisibility="True">
            </controls:CustomTabView>

            <Button
                Text="Add tab"
                Clicked="Button_Clicked1"/>

            <Label Text="SemanticZoom"
                FontSize="28"
                FontAttributes="Bold" />

            <Label Text="Click the toggle button (or a group header) to zoom out; click a group tile to jump to that group."
                FontSize="14" />

            <Button
                x:Name="ToggleZoomButton"
                Text="Zoom out"
                HorizontalOptions="Start"
                Clicked="OnToggleZoomClicked"/>

            <controls:SemanticZoom
                x:Name="AnimalsSemanticZoom"
                HeightRequest="420"
                IsZoomedInViewHeaderSticky="True">
                <controls:SemanticZoom.ZoomedInView>
                    <CollectionView
                        x:Name="ZoomedInCollection"
                        IsGrouped="True"
                        BackgroundColor="#1E1E24">
                        <CollectionView.GroupHeaderTemplate>
                            <DataTemplate x:DataType="local:AnimalGroup">
                                <Label Text="{Binding Name}"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="DodgerBlue"
                                       Padding="10,8"
                                       BackgroundColor="#2A2A33">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnGroupHeaderTapped"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </DataTemplate>
                        </CollectionView.GroupHeaderTemplate>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Label Text="{Binding .}"
                                       FontSize="16"
                                       Padding="24,6"/>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </controls:SemanticZoom.ZoomedInView>
                <controls:SemanticZoom.ZoomedOutView>
                    <CollectionView
                        x:Name="ZoomedOutCollection"
                        SelectionMode="Single"
                        BackgroundColor="#1E1E24">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="3"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="local:AnimalGroup">
                                <Border StrokeThickness="1"
                                        Stroke="#444"
                                        BackgroundColor="#2A2A33"
                                        Margin="8"
                                        StrokeShape="RoundRectangle 8">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnGroupTileTapped"/>
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Padding="12" Spacing="4">
                                        <Label Text="{Binding Name}"
                                               FontSize="22"
                                               FontAttributes="Bold"
                                               TextColor="DodgerBlue"
                                               HorizontalOptions="Center"/>
                                        <Label Text="{Binding Count, StringFormat='{0} items'}"
                                               FontSize="13"
                                               HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </controls:SemanticZoom.ZoomedOutView>
            </controls:SemanticZoom>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
